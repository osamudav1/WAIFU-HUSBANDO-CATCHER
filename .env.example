# ── Telegram Bot ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username

# ── Owner & Admin ──────────────────────────────────────────────────────────────
OWNER_ID=123456789
SUDO_IDS=123456789,987654321

# ── Telegram Group/Channel IDs ────────────────────────────────────────────────
GROUP_ID=-100xxxxxxxxxx
CHARA_CHANNEL_ID=-100xxxxxxxxxx
FILE_STORE_CHAT_ID=-100xxxxxxxxxx

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=waifu_bot

# ── Bot Settings ──────────────────────────────────────────────────────────────
SUPPORT_CHAT=your_support_chat
UPDATE_CHAT=your_update_channel
PHOTO_URLS=https://example.com/photo1.jpg,https://example.com/photo2.jpg
DROP_INTERVAL_MINUTES=15
DEFAULT_MSG_FREQUENCY=5

# ── AI (Optional) ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GROQ_API_KEY=
